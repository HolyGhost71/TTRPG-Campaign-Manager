generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Campaign {
  id          Int      @id @default(autoincrement())
  name        String
  description String?

  entities    Entity[]
}

model Entity {
  id          Int      @id @default(autoincrement())

  campaignId  Int

  type        EntityType
  name        String
  description String?
  dmNotes     String?
  playerNotes String?

  campaign Campaign @relation(fields: [campaignId], references: [id])

  npcDetails  NPCDetails?
}

model NPCDetails {
  id          Int      @id @default(autoincrement())
  entityId    Int      @unique

  species     String?
  location    String?
  age         String?
  status      String?
  appearance  String?

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
}

enum EntityType {
  NPC
  LOCATION
  ITEM
  QUEST
  PLAYER
}